// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  IN_TRANSIT
  DELAYED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  SCHEDULED
  PENDING_PARTS
  ACTIVE
  CLOSED
}

enum ExpenseType {
  TOLL
  MAINTENANCE
  OTHER
}

enum VehicleDocumentType {
  REGISTRATION
  INSURANCE
  FITNESS
  POLLUTION
  OTHER
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role
  driver       Driver?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  // Audit Relations
  vehiclesCreated     Vehicle[]        @relation("VehicleCreatedBy")
  vehiclesUpdated     Vehicle[]        @relation("VehicleUpdatedBy")
  driversCreated      Driver[]         @relation("DriverCreatedBy")
  driversUpdated      Driver[]         @relation("DriverUpdatedBy")
  tripsCreated        Trip[]           @relation("TripCreatedBy")
  tripsUpdated        Trip[]           @relation("TripUpdatedBy")
  maintenanceCreated MaintenanceLog[] @relation("MaintenanceCreatedBy")
  maintenanceUpdated MaintenanceLog[] @relation("MaintenanceUpdatedBy")
  fuelLogsCreated    FuelLog[]        @relation("FuelLogCreatedBy")
  fuelLogsUpdated    FuelLog[]        @relation("FuelLogUpdatedBy")
  expensesCreated     Expense[]        @relation("ExpenseCreatedBy")
  expensesUpdated     Expense[]        @relation("ExpenseUpdatedBy")
}

model Vehicle {
  id                 String           @id @default(uuid())
  registrationNumber  String           @unique
  name               String
  type               String
  maxLoadCapacity    Float
  odometer           Float            @default(0)
  acquisitionCost    Decimal          @db.Decimal(10, 2)
  status             VehicleStatus    @default(AVAILABLE)
  region             String?

  trips              Trip[]
  maintenanceLogs    MaintenanceLog[]
  fuelLogs           FuelLog[]
  expenses           Expense[]
  documents         VehicleDocument[]

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?

  // Audit Fields
  createdById        String?
  createdBy          User?            @relation("VehicleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById        String?
  updatedBy          User?            @relation("VehicleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  
  @@index([status])
  @@index([type])
  @@index([region])
}

model Driver {
  id                String       @id @default(uuid())
  userId            String?      @unique
  user              User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  name              String
  licenseNumber     String       @unique
  licenseCategory   String
  licenseExpiryDate DateTime
  contactNumber     String
  safetyScore       Float        @default(100)
  status            DriverStatus @default(AVAILABLE)

  trips             Trip[]

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  // Audit Fields
  createdById       String?
  createdBy         User?        @relation("DriverCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById       String?
  updatedBy         User?        @relation("DriverUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([licenseExpiryDate])
}

model Location {
  id              String       @id @default(uuid())
  name            String       @unique
  address         String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  tripsSource     Trip[]       @relation("TripSource")
  tripsDestination Trip[]      @relation("TripDestination")
}

model Vendor {
  id              String           @id @default(uuid())
  name            String           @unique
  contactInfo     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  maintenanceLogs MaintenanceLog[]
}

model Trip {
  id              String     @id @default(uuid())
  tripNumber      String     @unique @default(uuid())

  sourceLocationId String
  sourceLocation   Location  @relation("TripSource", fields: [sourceLocationId], references: [id])
  destinationLocationId String
  destinationLocation Location @relation("TripDestination", fields: [destinationLocationId], references: [id])

  vehicleId       String
  vehicle         Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  driverId        String
  driver          Driver     @relation(fields: [driverId], references: [id], onDelete: Restrict)

  cargoWeight     Float
  plannedDistance Float
  actualDistance  Float?
  startingOdometer Float?
  endingOdometer   Float?
  fuelConsumed    Float?
  revenue         Decimal?   @db.Decimal(10, 2)

  status          TripStatus @default(DRAFT)
  dispatchedAt    DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?

  fuelLogs        FuelLog[]
  expenses        Expense[]

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  // Audit Fields
  createdById     String?
  createdBy       User?      @relation("TripCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById     String?
  updatedBy       User?      @relation("TripUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([driverId])
  @@index([status])
  @@index([createdAt])
  @@index([dispatchedAt])
  @@index([completedAt])
}

model MaintenanceLog {
  id              String            @id @default(uuid())
  vehicleId       String
  vehicle         Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  maintenanceType String?
  description     String
  vendorId        String?
  vendor          Vendor?           @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  priority        String?
  cost            Decimal           @db.Decimal(10, 2)
  status          MaintenanceStatus @default(ACTIVE)
  startedAt       DateTime          @default(now())
  closedAt        DateTime?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  // Audit Fields
  createdById     String?
  createdBy       User?             @relation("MaintenanceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById     String?
  updatedBy       User?             @relation("MaintenanceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([status])
  @@index([startedAt])
}

model FuelLog {
  id              String   @id @default(uuid())
  vehicleId       String
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  tripId          String?
  trip            Trip?    @relation(fields: [tripId], references: [id], onDelete: Restrict)

  liters          Float
  pricePerLiter   Decimal? @db.Decimal(10, 2)
  cost            Decimal  @db.Decimal(10, 2)
  fuelStation     String?
  odometer        Float?
  date            DateTime @default(now())

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Audit Fields
  createdById     String?
  createdBy       User?    @relation("FuelLogCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById     String?
  updatedBy       User?    @relation("FuelLogUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([tripId])
  @@index([date])
}

model Expense {
  id              String      @id @default(uuid())

  vehicleId       String
  vehicle         Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  tripId          String?
  trip            Trip?       @relation(fields: [tripId], references: [id], onDelete: Restrict)

  type            ExpenseType
  amount          Decimal     @db.Decimal(10, 2)
  date            DateTime    @default(now())
  description     String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  // Audit Fields
  createdById     String?
  createdBy       User?       @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById     String?
  updatedBy       User?       @relation("ExpenseUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([tripId])
  @@index([type])
  @@index([date])
}

model VehicleDocument {
  id          String             @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  documentType VehicleDocumentType
  documentUrl  String
  expiryDate   DateTime?
  notes        String?

  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  deletedAt    DateTime?

  @@index([vehicleId])
  @@index([documentType])
  @@index([expiryDate])
}

model ActivityLog {
  id          String        @id @default(uuid())
  type        String
  entityName  String
  entityId    String
  message     String
  metadata    Json?

  createdAt   DateTime      @default(now())

  @@index([type])
  @@index([entityName, entityId])
  @@index([createdAt])
}